# Caddy configuration for WP-AI with split domains
# Architecture: Cloudflare → HAProxy (SSL termination) → Caddy (HTTP) → Services
# - app.ragbaz.cc: Next.js web app + APIs
# - *.ragbaz.cc: Tenant hostnames routed by MCP
#
# Caddy listens on HTTP only - HAProxy handles HTTPS

# Main web application - All frontend endpoints
http://app.ragbaz.cc {
    # HAProxy forwards HTTP traffic after SSL termination
    # Trust X-Forwarded-* headers from HAProxy

    # Logging
    log {
        output file /var/log/caddy/app-access.log {
            roll_size 100MB
            roll_keep 5
        }
        format json
    }

    # MCP Server API (for internal app use)
    @mcpapi {
        path /api/mcp/*
    }

    @mcp_preflight {
        method OPTIONS
        path /api/mcp/*
    }
    handle @mcp_preflight {
        header Access-Control-Allow-Origin "{http.request.header.Origin}"
        header Access-Control-Allow-Methods "POST, OPTIONS"
        header Access-Control-Allow-Headers "Content-Type, Authorization"
        header Access-Control-Allow-Credentials "true"
        respond "" 204
    }

    handle @mcpapi {
        # Rewrite /api/mcp to /mcp so internal MCP server routes match
        uri replace /api/mcp /mcp

        reverse_proxy mcp-server:8000 {
            header_up Host {host}
            header_up X-Real-IP {header.X-Real-IP}
            header_up X-Forwarded-For {header.X-Forwarded-For}
            header_up X-Forwarded-Proto {header.X-Forwarded-Proto}

            # SSE support for streaming
            flush_interval -1
        }
    }

    # Documentation site
    @docs {
        path /docs*
    }
    handle @docs {
        reverse_proxy docs:80 {
            header_up Host {host}
            header_up X-Real-IP {header.X-Real-IP}
            header_up X-Forwarded-For {header.X-Forwarded-For}
            header_up X-Forwarded-Proto {header.X-Forwarded-Proto}
        }
    }

    # Health check endpoint
    handle /health {
        respond "OK" 200
    }

    # Next.js frontend (default - handles all other routes)
    handle {
        reverse_proxy webedit:3000 {
            header_up Host {host}
            header_up X-Real-IP {header.X-Real-IP}
            header_up X-Forwarded-For {header.X-Forwarded-For}
            header_up X-Forwarded-Proto {header.X-Forwarded-Proto}

            # WebSocket support for Next.js HMR (development)
            header_up Upgrade {http.request.header.Upgrade}
            header_up Connection {http.request.header.Connection}
        }
    }
}
# Multi-tenant wildcard routing
# Matches: {view}-{tenant}.ragbaz.cc and {tenant}.ragbaz.cc
# Routes dynamically via MCP server's /routing/resolve endpoint
http://*.ragbaz.cc {
    log {
        output file /var/log/caddy/tenant-access.log {
            roll_size 100MB
            roll_keep 5
        }
        format json
    }

    # Rewrite to tenant proxy path on MCP server
    rewrite * /routing/proxy{uri}

    reverse_proxy mcp-server:8000 {
        header_up X-Forwarded-Host {http.request.host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {header.X-Forwarded-Proto}
        flush_interval -1
    }
}

# Custom external domains — on-demand TLS
# When a verified custom domain hits Caddy, it auto-fetches a cert
# and routes to the correct tenant view via the route resolver
#
# NOTE: This block is disabled until Caddy is configured as the TLS
# terminator (currently HAProxy handles TLS). Enable when ready:
#
# https:// {
#     tls {
#         on_demand {
#             ask http://mcp-server:8000/routing/tls-check
