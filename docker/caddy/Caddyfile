# Caddy configuration for WP-AI production deployment
# Running behind HAProxy - HAProxy handles SSL termination
# Caddy serves HTTP only (no automatic HTTPS redirects)
#
# Usage:
# 1. Install Caddy: https://caddyserver.com/docs/install
# 2. Replace ragbaz.xyz with your actual domain
# 3. Run: caddy run --config /path/to/Caddyfile

# Listen on HTTP only - HAProxy handles SSL termination
http://ragbaz.xyz {
    # HAProxy handles HTTPS
    # Caddy just routes requests to backend services

    # Security headers handled by HAProxy

    # Logging
    log {
        output file /var/log/caddy/wp-ai-access.log
        format json
    }

    # WordPress admin panel
    @wpadmin {
        path /wp-admin* /wp-login.php*
    }
    handle @wpadmin {
        reverse_proxy wordpress:80 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # WordPress static assets
    @wpcontent {
        path /wp-content/* /wp-includes/*
    }
    handle @wpcontent {
        reverse_proxy wordpress:80 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
        # Cache static assets
        header Cache-Control "public, max-age=2592000"
    }

    # Documentation site
    @docs {
        path /docs*
    }
    handle @docs {
        reverse_proxy docs:80 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # GraphQL endpoint
    @graphql {
        path /graphql*
    }
    handle @graphql {
        reverse_proxy wordpress:80 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}

            # Disable buffering for streaming responses
            flush_interval -1
        }
    }

    # MCP Server API
    @mcpapi {
        path /api/mcp/*
    }
    handle @mcpapi {
        # Strip /api/mcp prefix
        uri strip_prefix /api/mcp

        reverse_proxy mcp-server:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}

            # SSE support for streaming
            flush_interval -1
        }
    }

    # Next.js frontend (default)
    handle {
        reverse_proxy web:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}

            # WebSocket support for Next.js HMR
            header_up Upgrade {http.request.header.Upgrade}
            header_up Connection {http.request.header.Connection}
        }
    }
}

# www subdomain redirect handled by HAProxy
