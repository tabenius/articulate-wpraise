# Caddy configuration for WP-AI with split domains
# Architecture: Cloudflare → HAProxy (SSL termination) → Caddy (HTTP) → Services
# - app.ragbaz.xyz: Next.js web app + APIs
# - my.ragbaz.xyz: WordPress backend
#
# Caddy listens on HTTP only - HAProxy handles HTTPS

# Main web application - All frontend endpoints
http://app.ragbaz.xyz {
    # HAProxy forwards HTTP traffic after SSL termination
    # Trust X-Forwarded-* headers from HAProxy

    # Logging
    log {
        output file /var/log/caddy/app-access.log {
            roll_size 100MB
            roll_keep 5
        }
        format json
    }

    # MCP Server API (for internal app use)
    @mcpapi {
        path /api/mcp/*
    }

    @mcp_preflight {
        method OPTIONS
        path /api/mcp/*
    }
    handle @mcp_preflight {
        respond "" 204 {
            header Access-Control-Allow-Origin "{http.request.header.Origin}"
            header Access-Control-Allow-Methods "POST, OPTIONS"
            header Access-Control-Allow-Headers "Content-Type, Authorization"
            header Access-Control-Allow-Credentials "true"
        }
    }

    handle @mcpapi {
        # Rewrite /api/mcp to /mcp so internal MCP server routes match
        uri replace /api/mcp /mcp

        reverse_proxy mcp-server:8000 {
            header_up Host {host}
            header_up X-Real-IP {header.X-Real-IP}
            header_up X-Forwarded-For {header.X-Forwarded-For}
            header_up X-Forwarded-Proto {header.X-Forwarded-Proto}

            # SSE support for streaming
            flush_interval -1
        }
    }

    # Documentation site
    @docs {
        path /docs*
    }
    handle @docs {
        reverse_proxy docs:80 {
            header_up Host {host}
            header_up X-Real-IP {header.X-Real-IP}
            header_up X-Forwarded-For {header.X-Forwarded-For}
            header_up X-Forwarded-Proto {header.X-Forwarded-Proto}
        }
    }

    # Health check endpoint
    handle /health {
        respond "OK" 200
    }

    # Next.js frontend (default - handles all other routes)
    handle {
        reverse_proxy webedit:3000 {
            header_up Host {host}
            header_up X-Real-IP {header.X-Real-IP}
            header_up X-Forwarded-For {header.X-Forwarded-For}
            header_up X-Forwarded-Proto {header.X-Forwarded-Proto}

            # WebSocket support for Next.js HMR (development)
            header_up Upgrade {http.request.header.Upgrade}
            header_up Connection {http.request.header.Connection}
        }
    }
}

# WordPress backend - Full WordPress access
http://my.ragbaz.xyz {
    # HAProxy forwards HTTP traffic after SSL termination

    # Logging
    log {
        output file /var/log/caddy/wp-access.log {
            roll_size 100MB
            roll_keep 5
        }
        format json
    }

    # Block xmlrpc.php (common attack vector)
    @xmlrpc {
        path /xmlrpc.php
    }
    handle @xmlrpc {
        respond 403
    }

    # WordPress login
    @wplogin {
        path /wp-login.php
    }
    handle @wplogin {
        reverse_proxy wordpress:80 {
            header_up Host {host}
            header_up X-Real-IP {header.X-Real-IP}
            header_up X-Forwarded-For {header.X-Forwarded-For}
            header_up X-Forwarded-Proto {header.X-Forwarded-Proto}
        }
    }

    # WordPress admin panel
    @wpadmin {
        path /wp-admin/*
    }
    handle @wpadmin {
        reverse_proxy wordpress:80 {
            header_up Host {host}
            header_up X-Real-IP {header.X-Real-IP}
            header_up X-Forwarded-For {header.X-Forwarded-For}
            header_up X-Forwarded-Proto {header.X-Forwarded-Proto}
        }
    }

    # WordPress REST API
    @wpapi {
        path /wp-json/*
    }
    handle @wpapi {
        # Enable CORS for API access
        @origin header Origin *
        header @origin Access-Control-Allow-Origin "{http.request.header.Origin}"
        header @origin Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
        header @origin Access-Control-Allow-Headers "Authorization, Content-Type"
        header @origin Access-Control-Allow-Credentials "true"

        reverse_proxy wordpress:80 {
            header_up Host {host}
            header_up X-Real-IP {header.X-Real-IP}
            header_up X-Forwarded-For {header.X-Forwarded-For}
            header_up X-Forwarded-Proto {header.X-Forwarded-Proto}
        }
    }

    # GraphQL endpoint
    @graphql {
        path /graphql*
    }
    handle @graphql {
        reverse_proxy wordpress:80 {
            header_up Host {host}
            header_up X-Real-IP {header.X-Real-IP}
            header_up X-Forwarded-For {header.X-Forwarded-For}
            header_up X-Forwarded-Proto {header.X-Forwarded-Proto}

            # Disable buffering for streaming
            flush_interval -1
        }
    }

    # Static assets - aggressive caching
    @static {
        path /wp-content/* /wp-includes/*
        not path /wp-content/uploads/wpcf7_uploads/*
    }
    handle @static {
        reverse_proxy wordpress:80 {
            header_up Host {host}
            header_up X-Real-IP {header.X-Real-IP}
            header_up X-Forwarded-For {header.X-Forwarded-For}
            header_up X-Forwarded-Proto {header.X-Forwarded-Proto}
        }

        # Cache headers (HAProxy/Cloudflare will respect these)
        header {
            Cache-Control "public, max-age=31536000, immutable"
            X-Content-Type-Options "nosniff"
        }
    }

    # WordPress frontend (default)
    handle {
        reverse_proxy wordpress:80 {
            header_up Host {host}
            header_up X-Real-IP {header.X-Real-IP}
            header_up X-Forwarded-For {header.X-Forwarded-For}
            header_up X-Forwarded-Proto {header.X-Forwarded-Proto}
        }
    }
}

# Multi-tenant wildcard routing
# Matches: {view}-{tenant}.ragbaz.xyz and {tenant}.ragbaz.xyz
# Routes dynamically via MCP server's /routing/resolve endpoint
http://*.ragbaz.xyz {
    log {
        output file /var/log/caddy/tenant-access.log {
            roll_size 100MB
            roll_keep 5
        }
        format json
    }

    # Rewrite to tenant proxy path on MCP server
    rewrite * /routing/proxy{uri}

    reverse_proxy mcp-server:8000 {
        header_up X-Forwarded-Host {http.request.host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {header.X-Forwarded-Proto}
        flush_interval -1
    }
}

# Custom external domains — on-demand TLS
# When a verified custom domain hits Caddy, it auto-fetches a cert
# and routes to the correct tenant view via the route resolver
#
# NOTE: This block is disabled until Caddy is configured as the TLS
# terminator (currently HAProxy handles TLS). Enable when ready:
