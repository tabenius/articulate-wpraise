# Anthropic API Key (optional if using BYOK in UI)
ANTHROPIC_API_KEY=

# MCP Server URL
# Local development: http://localhost:8000
# Production (same server): http://localhost:8000
# Production (separate server): http://mcp-server-ip:8000
MCP_SERVER_URL=http://localhost:8000

# WordPress URL (for backend connections)
# Local: http://localhost:8080
# Production: https://yourdomain.com or http://wordpress-server:8080
WP_URL=http://localhost:8080

# Default WordPress Connection (auto-created for new users)
# IMPORTANT: These URLs must be accessible from the frontend user's browser
# Local development: http://localhost:8080
# Production: Use your public domain (e.g., https://yourdomain.com)
NEXT_PUBLIC_DEFAULT_WP_NAME=Local WordPress
NEXT_PUBLIC_DEFAULT_WP_URL=http://localhost:8080
NEXT_PUBLIC_DEFAULT_WP_GRAPHQL_ENDPOINT=http://localhost:8080/graphql
NEXT_PUBLIC_DEFAULT_WP_USER=admin
# This one stays server-side only (no NEXT_PUBLIC_)
# Generate in WordPress: Admin → Profile → Application Passwords
DEFAULT_WP_APP_PASSWORD=
