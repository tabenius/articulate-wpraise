# Anthropic API Key (optional if using BYOK in UI)
ANTHROPIC_API_KEY=

# MCP Server URL (backend only - Next.js server to MCP server)
# Local development: http://localhost:8000
# Production (same server): http://localhost:8000
# Production (separate server): http://mcp-server-ip:8000
MCP_SERVER_URL=http://localhost:8000

# Default WordPress Connection (auto-created for new users)
# IMPORTANT: These are server-side only - users NEVER access WordPress directly
# All WordPress requests are proxied through Next.js API routes
# URLs can be internal (localhost, docker hostnames) since only the backend uses them
DEFAULT_WP_NAME=Local WordPress
DEFAULT_WP_URL=http://localhost:8080
DEFAULT_WP_GRAPHQL_ENDPOINT=http://localhost:8080/graphql
DEFAULT_WP_USER=admin
# Generate in WordPress: Admin → Profile → Application Passwords
DEFAULT_WP_APP_PASSWORD=
